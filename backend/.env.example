# Application
APP_NAME=SecureZone
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Database
DATABASE_URL=postgresql+asyncpg://securezone:securezone@localhost:5432/securezone_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=securezone

# Wazuh
WAZUH_MANAGER_URL=https://localhost:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=change-me

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Scanning
NMAP_PATH=/usr/bin/nmap
OPENVAS_URL=http://localhost:9390

# Notifications
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=securezone@company.local

# Scheduler
SCAN_SCHEDULER_TIMEZONE=Africa/Tunis
